    "version": "0.2.0",
    "configurations": [

        {
            "name": "Cortex Debug Nucleo on Pi",
            "cwd": "${workspaceFolder}",
            "executable": "/home/ndrwldr/robot_ws/build/Debug/serial-frtos.elf",
            "request": "launch",
            "type": "cortex-debug",
            "servertype": "openocd",
            "runToEntryPoint": "main",
            "device": "STM32G431RB",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32g4x.cfg"
            ],
            "gdbPath": "gdb-multiarch",
            "showDevDebugOutput": "raw",
            "preLaunchCommands": [
                "set substitute-path /home/ndrwldr/n64-code/serial-frtos /home/ndrwldr/robot_ws"
            ]
        }
    ]
}